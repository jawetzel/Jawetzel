# Shared by the worker Dockerfile build AND Railway's Railpack build of the
# Next.js service. Keep this list additive (exclude obvious bloat only) —
# do NOT use `*` + `!worker/`, because that hides `src/` from the Next.js
# build context and breaks `next build` with "Couldn't find any `pages` or
# `app` directory".
node_modules
.next
tmp
data
.git
coverage
out
build
*.tsbuildinfo
